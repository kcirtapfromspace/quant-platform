# ─────────────────────────────────────────────────────────────────────────────
# Alpaca Paper Trading — Environment Configuration
# QUA-54: $1M notional paper trading account for Regime-Adaptive Momentum
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your Alpaca paper trading credentials.
# Never commit a .env file with real API keys.
#
# Obtain paper trading keys at:  https://app.alpaca.markets/paper-trading/account
# ─────────────────────────────────────────────────────────────────────────────

# ── Alpaca credentials (REQUIRED) ────────────────────────────────────────────
ALPACA_API_KEY=REPLACE_WITH_PAPER_API_KEY_ID
ALPACA_SECRET_KEY=REPLACE_WITH_PAPER_SECRET_KEY

# Force paper trading endpoint (safety default — do NOT set to false in prod)
ALPACA_PAPER=true

# ── Starting notional capital ─────────────────────────────────────────────────
# Per QUA-22 CEO decision: $1,000,000 starting capital for paper trading.
# This is used by the runner to initialise portfolio tracking and position sizing.
QUANT_PAPER_NOTIONAL=1000000

# ── Universe (100-name S&P 500 liquid names + 10 ETF overlays) ───────────────
# Point this at the universe file generated by QUA-52 once complete.
# Falls back to the default 23-symbol dev universe until QUA-52 ships.
# QUANT_UNIVERSE_FILE=data/universe_100.txt

# ── Database ──────────────────────────────────────────────────────────────────
QUANT_DB_PATH=data/paper_trading.duckdb

# ── Monitoring ────────────────────────────────────────────────────────────────
PROMETHEUS_METRICS_PORT=8000
PUSHGATEWAY_URL=http://localhost:9091

# Slack webhook for alerts (set in alertmanager/alertmanager.yml)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/REPLACE_ME

# ── CRO drawdown thresholds (read by the runner — match Grafana dashboard) ───
# Yellow: 10%  |  Orange: 15%  |  Red (halt): 20%
# Circuit breaker fires at 8% DD or -3% daily P&L — see alerts.yml
QUANT_DD_YELLOW=0.10
QUANT_DD_ORANGE=0.15
QUANT_DD_RED=0.20
QUANT_DD_CIRCUIT_BREAKER=0.08
QUANT_DAILY_PNL_HALT=-0.03

# ── Grafana / Prometheus (docker-compose defaults) ────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme
