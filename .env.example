# =============================================================================
# .env.example — copy to .env and fill in values
# All variables are optional unless marked REQUIRED
# =============================================================================

# -----------------------------------------------------------------------------
# Application environment
# -----------------------------------------------------------------------------
QUANT_ENV=development    # development | test | production

# -----------------------------------------------------------------------------
# Database — PostgreSQL / TimescaleDB  (REQUIRED for most features)
# -----------------------------------------------------------------------------
POSTGRES_USER=quant
POSTGRES_PASSWORD=quantpass
POSTGRES_DB=quant
TIMESCALEDB_PORT=5432

# Full DSN — used by SQLAlchemy / Alembic.
# Constructed from the above vars when running via docker-compose.
DATABASE_URL=postgresql://quant:quantpass@localhost:5432/quant

# -----------------------------------------------------------------------------
# Redis — feature cache and signal distribution  (REQUIRED for RedisFeatureCache)
# -----------------------------------------------------------------------------
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0
REDIS_KEY_PREFIX=quant:    # optional namespace prefix for all cache keys

# -----------------------------------------------------------------------------
# MinIO / S3-compatible object storage  (REQUIRED for parquet data lake)
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# S3 client settings (boto3 / s3fs)
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_REGION=us-east-1             # MinIO ignores region but boto3 requires a value

# Bucket names
MINIO_BUCKET_MARKET_DATA=quant-market-data
MINIO_BUCKET_BACKTEST=quant-backtest
MINIO_BUCKET_MODELS=quant-models

# -----------------------------------------------------------------------------
# Monitoring — Grafana admin credentials
# -----------------------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme   # CHANGE IN PRODUCTION

# -----------------------------------------------------------------------------
# DuckDB — local OLAP database for backtesting
# -----------------------------------------------------------------------------
QUANT_DB_PATH=~/.quant/market.duckdb   # path to local DuckDB file

# -----------------------------------------------------------------------------
# Data universe
# -----------------------------------------------------------------------------
# QUANT_UNIVERSE_FILE=/path/to/universe.txt   # one symbol per line; falls back to built-in

# -----------------------------------------------------------------------------
# Execution adapters (optional — configure whichever broker you use)
# -----------------------------------------------------------------------------

# Alpaca Markets
# ALPACA_API_KEY=
# ALPACA_API_SECRET=
# ALPACA_BASE_URL=https://paper-api.alpaca.markets   # paper trading endpoint

# Interactive Brokers
# IB_HOST=127.0.0.1
# IB_PORT=7497
# IB_CLIENT_ID=1

# CCXT (crypto)
# CCXT_EXCHANGE=binance
# CCXT_API_KEY=
# CCXT_API_SECRET=

# -----------------------------------------------------------------------------
# Prometheus / Pushgateway
# -----------------------------------------------------------------------------
PROMETHEUS_PUSHGATEWAY_URL=http://localhost:9091
METRICS_PORT=8000   # HTTP scrape endpoint port for long-running services
