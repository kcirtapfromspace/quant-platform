{
  "id": null,
  "uid": "quant-strategy-pnl",
  "title": "Quant Platform — Strategy PnL & Drawdown",
  "description": "Strategy performance: fill rates, order counts by symbol/side, drawdown, and circuit breaker state.",
  "tags": ["quant", "strategy", "pnl", "risk"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-7d", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Circuit Breaker",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "ACTIVE", "color": "green" }, "1": { "text": "TRIPPED", "color": "red" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "quant_circuit_breaker_tripped",
          "legendFormat": "Trading",
          "instant": true
        }
      ]
    },
    {
      "id": 2,
      "type": "gauge",
      "title": "Current Drawdown",
      "gridPos": { "x": 4, "y": 0, "w": 5, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 0.2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.1 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "quant_drawdown_current",
          "legendFormat": "Drawdown",
          "instant": true
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Total Orders Submitted",
      "gridPos": { "x": 9, "y": 0, "w": 5, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(quant_orders_submitted_total)",
          "legendFormat": "Submitted",
          "instant": true
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Fill Rate",
      "gridPos": { "x": 14, "y": 0, "w": 5, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 0.9 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "quant_fill_rate",
          "legendFormat": "Fill Rate",
          "instant": true
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Open Positions",
      "gridPos": { "x": 19, "y": 0, "w": 5, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "quant_positions_open",
          "legendFormat": "Open",
          "instant": true
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Drawdown History",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "custom": { "fillOpacity": 20, "lineWidth": 2 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Drawdown" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "quant_drawdown_current",
          "legendFormat": "Drawdown"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Orders by Side (rate 15m)",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 7 },
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(quant_orders_submitted_total{side=\"buy\"}[15m]))",
          "legendFormat": "Buy (submitted)"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(quant_orders_submitted_total{side=\"sell\"}[15m]))",
          "legendFormat": "Sell (submitted)"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(quant_orders_filled_total{side=\"buy\"}[15m]))",
          "legendFormat": "Buy (filled)"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(quant_orders_filled_total{side=\"sell\"}[15m]))",
          "legendFormat": "Sell (filled)"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Order Latency Percentiles",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 7 },
      "fieldConfig": {
        "defaults": { "unit": "s" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(quant_order_latency_seconds_bucket[15m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(quant_order_latency_seconds_bucket[15m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(quant_order_latency_seconds_bucket[15m])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 9,
      "type": "gauge",
      "title": "Daily P&L %",
      "description": "Daily P&L as % of starting notional. Panel turns red at -3% — matches PaperDailyPnLHalt alert threshold.",
      "gridPos": { "x": 0, "y": 19, "w": 6, "h": 5 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": true,
        "showThresholdMarkers": true,
        "orientation": "horizontal"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "min": -0.05,
          "max": 0.05,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": -0.03 },
              { "color": "green", "value": 0 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "quant_paper_daily_pnl_pct",
          "legendFormat": "Daily P&L %",
          "instant": true
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Cumulative P&L",
      "description": "Running cumulative P&L in USD since strategy inception.",
      "gridPos": { "x": 6, "y": 19, "w": 18, "h": 8 },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 0 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "quant_paper_pnl_cumulative",
          "legendFormat": "Cumulative P&L"
        }
      ]
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Rolling Sharpe (30d)",
      "description": "Annualised Sharpe ratio over the trailing 30 trading days. Shows N/A when fewer than 10 samples are available.",
      "gridPos": { "x": 0, "y": 27, "w": 8, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 2,
          "noValue": "N/A",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 1.0 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "quant_paper_sharpe_rolling_30d",
          "legendFormat": "Sharpe 30d",
          "instant": true
        }
      ]
    },
    {
      "id": 12,
      "type": "stat",
      "title": "Rolling Sharpe (7d)",
      "description": "Annualised Sharpe ratio over the trailing 7 trading days. Shows N/A when fewer than 3 samples are available.",
      "gridPos": { "x": 8, "y": 27, "w": 8, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 2,
          "noValue": "N/A",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 1.0 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "quant_paper_sharpe_rolling_7d",
          "legendFormat": "Sharpe 7d",
          "instant": true
        }
      ]
    },
    {
      "id": 13,
      "type": "stat",
      "title": "Running Profit Factor",
      "description": "Gross winning returns / abs(gross losing returns) over the historical return window. Shows N/A when there are no losing periods.",
      "gridPos": { "x": 16, "y": 27, "w": 8, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 2,
          "noValue": "N/A",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 1.0 },
              { "color": "green", "value": 1.5 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "quant_paper_profit_factor",
          "legendFormat": "Profit Factor",
          "instant": true
        }
      ]
    },
    {
      "id": 14,
      "type": "stat",
      "title": "Gross Exposure (USD)",
      "description": "Total absolute notional value of simulated portfolio. Threshold alerts at $800k (yellow) and $950k (red) vs $1M notional.",
      "gridPos": { "x": 0, "y": 31, "w": 6, "h": 8 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 800000 },
              { "color": "red", "value": 950000 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "quant_paper_gross_exposure_usd",
          "legendFormat": "Gross Exposure",
          "instant": true
        }
      ]
    },
    {
      "id": 15,
      "type": "bargauge",
      "title": "Position Concentration (% NAV by Symbol)",
      "description": "Per-symbol weight as fraction of portfolio NAV. Sourced from optimizer target weights after each rebalance.",
      "gridPos": { "x": 6, "y": 31, "w": 18, "h": 8 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 1,
          "min": 0,
          "max": 0.3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.2 },
              { "color": "red", "value": 0.25 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "quant_paper_position_weight",
          "legendFormat": "{{symbol}}",
          "instant": true
        }
      ]
    }
  ]
}
